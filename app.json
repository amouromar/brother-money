{
  "expo": {
    "name": "brother-money",
    "slug": "brother-money",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/custom/icon.png",
    "scheme": "brothermoney",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/custom/icon-foreground.png",
        "backgroundImage": "./assets/images/custom/icon-background.png",
        "monochromeImage": "./assets/images/custom/icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.amourhamisiomar.brothermoney"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/custom/icon.png",
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df5c1e60-962a-43a3-aa71-add7002cae19"
      }
    }
  }
}
